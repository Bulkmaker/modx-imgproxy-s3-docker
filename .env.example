# ── Приложение (MODX) ────────────────────────────────────────────────────
APP_PORT=8080
SITE_URL=http://localhost:8080/

# ── База данных ──────────────────────────────────────────────────────────
DB_NAME=modx
DB_USER=modx
DB_PASS=modx
DB_ROOT_PASS=root
DB_PORT=3306
# Префикс таблиц MODX — должен совпадать с тем, что вы укажете при установке
TABLE_PREFIX=modx_

# ── phpMyAdmin ─────────────────────────────────────────────────────────────
PMA_PORT=8081

# ── Продакшн за Traefik (только для docker-compose.prod.yml / traefik/) ──
# Домен сайта (Traefik роутит по нему и выпускает TLS-сертификат)
DOMAIN=example.com
# Email для Let's Encrypt
ACME_EMAIL=you@example.com

# ── S3 (где лежат ОРИГИНАЛЫ картинок) ────────────────────────────────────
# Имя бакета подставляется в nginx-конфиг и в URL imgproxy
S3_BUCKET=my-media-bucket
# Endpoint S3-совместимого хранилища (AWS, Backblaze, Beget, Selectel, MinIO…)
IMGPROXY_S3_ENDPOINT=https://s3.example-cloud.com
S3_ACCESS_KEY_ID=changeme
S3_SECRET_ACCESS_KEY=changeme
S3_REGION=us-east-1
